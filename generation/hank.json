{
  "$schema": "../hankweave-runtime/schemas/hank.schema.json",
  "meta": {
    "name": "disco-romana-phase-gen",
    "version": "1.0.0",
    "description": "Generate one phase of the Late Roman Republic game",
    "author": "disco-romana"
  },
  "overrides": {
    "model": "claude-sonnet"
  },
  "hank": [
    {
      "id": "generate",
      "name": "Generate Phase",
      "description": "Generate phase.json, all NPC folders with conversations, and the power shift conversation",
      "promptFile": "prompts/generate-phase.md",
      "model": "sonnet",
      "backendOverride": "llmlib-agent",
      "continuationMode": "fresh",
      "checkpointedFiles": [
        "phase.json",
        "characters/**/npc.json",
        "characters/**/convo_*.json",
        "power_shift/convo.json"
      ]
    },
    {
      "id": "validate",
      "name": "Validate Phase",
      "description": "Check all generated files for structural consistency and fix errors",
      "promptFile": "prompts/validate-phase.md",
      "model": "sonnet",
      "backendOverride": "llmlib-agent",
      "continuationMode": "fresh",
      "checkpointedFiles": [
        "validation_report.json",
        "characters/**/convo_*.json",
        "power_shift/convo.json"
      ]
    }
  ]
}